{
  "xsappname": "bpsync",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.user",
      "description": "Access the application"
    }
  ],
  "role-templates": [
    {
      "name": "Viewer",
      "description": "View access",
      "scope-references": ["$XSAPPNAME.user"]
    }
  ],
  "oauth2-configuration": {
    "redirect-uris": [
      "https://bpsync-approuter.cfapps.us10.hana.ondemand.com/login/callback",
      "https://bpsync-approuter.cfapps.us10.hana.ondemand.com/**"
    ],
    "token-validity": 43200,
    "refresh-token-validity": 2592000,
    "autoapprove": true
  }
}
